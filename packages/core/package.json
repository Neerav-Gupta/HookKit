{
	"name": "@hookkit-dev/core",
	"version": "0.0.3",
	"description": "HookKit core: provider registry, signature engine, event generator, dispatcher, harness",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Neerav-Gupta/HookKit.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/Neerav-Gupta/HookKit#readme",
	"bugs": {
		"url": "https://github.com/Neerav-Gupta/HookKit/issues"
	},
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"main": "./dist/index.cjs",
		"module": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"require": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsup",
		"test": "vitest run"
	},
	"dependencies": {
		"@hookkit-dev/fixtures": "workspace:*"
	},
	"devDependencies": {
		"@octokit/webhooks-methods": "^6.0.0",
		"@shopify/shopify-api": "^13.1.0",
		"@slack/bolt": "^4.7.3",
		"ajv": "^8.20.0",
		"discord-interactions": "^4.4.0",
		"standardwebhooks": "^1.0.0",
		"stripe": "^18.0.0"
	},
	"engines": {
		"node": ">=20"
	}
}
