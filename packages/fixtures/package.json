{
	"name": "@hookkit-dev/fixtures",
	"version": "0.0.2",
	"description": "Bundled, versioned, synthetic webhook payload fixtures for HookKit",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Neerav-Gupta/HookKit.git",
		"directory": "packages/fixtures"
	},
	"homepage": "https://github.com/Neerav-Gupta/HookKit#readme",
	"bugs": {
		"url": "https://github.com/Neerav-Gupta/HookKit/issues"
	},
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"fixtures",
		"manifest.json"
	],
	"publishConfig": {
		"main": "./dist/index.cjs",
		"module": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"require": "./dist/index.cjs"
			},
			"./package.json": "./package.json"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsup",
		"test": "vitest run"
	},
	"engines": {
		"node": ">=20"
	}
}
