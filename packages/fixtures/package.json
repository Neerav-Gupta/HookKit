{
	"name": "@hookkit-dev/fixtures",
	"version": "0.0.1",
	"description": "Bundled, versioned, synthetic webhook payload fixtures for HookKit",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"dist",
		"fixtures",
		"manifest.json"
	],
	"publishConfig": {
		"main": "./dist/index.cjs",
		"module": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"require": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsup",
		"test": "vitest run"
	},
	"engines": {
		"node": ">=20"
	}
}
