{
	"name": "@hookkit-dev/cli",
	"version": "0.0.3",
	"description": "HookKit dev CLI: trigger, replay, list, verify, listen, inspect",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Neerav-Gupta/HookKit.git",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/Neerav-Gupta/HookKit#readme",
	"bugs": {
		"url": "https://github.com/Neerav-Gupta/HookKit/issues"
	},
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"bin": {
		"hookkit": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"main": "./dist/index.cjs",
		"module": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"require": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsup",
		"test": "vitest run"
	},
	"dependencies": {
		"@hookkit-dev/fixtures": "workspace:*",
		"cac": "^6.7.14",
		"@hookkit-dev/inspector": "workspace:*"
	},
	"devDependencies": {
		"@hookkit-dev/core": "workspace:*"
	},
	"engines": {
		"node": ">=20"
	}
}
