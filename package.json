{
	"name": "hookkit-monorepo",
	"private": true,
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Neerav-Gupta/HookKit.git"
	},
	"homepage": "https://github.com/Neerav-Gupta/HookKit#readme",
	"bugs": {
		"url": "https://github.com/Neerav-Gupta/HookKit/issues"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"verify": "biome check . && pnpm -r typecheck && vitest run && pnpm -r build",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "vitest run",
		"build": "pnpm -r build",
		"publish:packages": "node scripts/publish-packages.mjs",
		"publish:packages:dry-run": "node scripts/publish-packages.mjs --dry-run",
		"hookkit": "node packages/cli/dist/cli.js"
	},
	"packageManager": "pnpm@11.9.0",
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^26.1.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	}
}
